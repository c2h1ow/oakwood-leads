<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Oakwood Suites Tiwanon — Lead Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sarabun:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/dashboard.css" />
</head>
<body>

  <!-- HEADER -->
  <header class="header">
    <div class="header-inner">
      <div class="header-brand">
        <div class="brand-logo">OS</div>
        <div>
          <div class="brand-name">Oakwood Suites Tiwanon</div>
          <div class="brand-sub">Lead Capture Dashboard</div>
        </div>
      </div>
      <div class="header-meta">
        <span class="live-dot"></span>
        <span id="clock" class="header-time"></span>
      </div>
    </div>
  </header>

  <main class="main">

    <!-- STAT CARDS -->
    <section class="stats-grid">
      <div class="stat-card stat-today">
        <div class="stat-icon">📥</div>
        <div class="stat-body">
          <div class="stat-value"><%= totalToday %></div>
          <div class="stat-label">Leads Today</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-body">
          <div class="stat-value"><%= totalLeads %></div>
          <div class="stat-label">Total Leads</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">🏆</div>
        <div class="stat-body">
          <div class="stat-value"><%= bookedLeads %></div>
          <div class="stat-label">Booked</div>
        </div>
      </div>
      <div class="stat-card stat-conversion">
        <div class="stat-icon">📈</div>
        <div class="stat-body">
          <div class="stat-value"><%= conversionRate %>%</div>
          <div class="stat-label">Conversion Rate</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">🗑️</div>
        <div class="stat-body">
          <div class="stat-value"><%= deletedLeads %></div>
          <div class="stat-label">Deleted Leads</div>
        </div>
      </div>
    </section>

    <!-- CHARTS ROW -->
    <section class="charts-row">

      <!-- By Channel -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Leads by Channel</h2>
        </div>
        <div class="card-body">
          <% const chTotal = byChannel.reduce((s,r) => s + parseInt(r.count), 0) || 1; %>
          <div class="channel-bars">
            <% byChannel.forEach(function(r) { %>
              <% const chClass = r.channel.startsWith('Line') ? 'bar-line' : r.channel.startsWith('Facebook') ? 'bar-fb' : 'bar-pkg'; %>
              <div class="channel-row">
                <div class="channel-label"><%= r.channel %></div>
                <div class="bar-track">
                  <div class="bar-fill <%= chClass %>" style="width:<%= Math.round(parseInt(r.count)/chTotal*100) %>%"></div>
                </div>
                <div class="channel-count"><%= r.count %></div>
              </div>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- By Package -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Leads by Package</h2>
        </div>
        <div class="card-body">
          <% if (byPackage.length === 0) { %>
            <p class="empty-hint">No package data yet</p>
          <% } else { %>
            <% const pkgTotal = byPackage.reduce((s, r) => s + parseInt(r.count), 0) || 1; %>
            <div class="pkg-list">
              <% byPackage.forEach(function(row, i) { %>
                <div class="pkg-row">
                  <div class="pkg-name"><%= row.package %></div>
                  <div class="bar-track">
                    <div class="bar-fill bar-pkg" style="width:<%= Math.round(parseInt(row.count)/pkgTotal*100) %>%"></div>
                  </div>
                  <div class="pkg-count"><%= row.count %></div>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- By Status -->
      <div class="card">
        <div class="card-header">
          <h2 class="card-title">Status Breakdown</h2>
        </div>
        <div class="card-body">
          <div class="status-pills">
            <% const statusMap = {}; byStatus.forEach(r => statusMap[r.status] = r.count); %>
            <% ['new','follow-up','booked','lost'].forEach(function(s) { %>
              <div class="status-pill-card status-<%= s %>">
                <div class="pill-count"><%= statusMap[s] || 0 %></div>
                <div class="pill-label"><%= s.charAt(0).toUpperCase() + s.slice(1) %></div>
              </div>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Peak Hours -->
      <div class="card" style="grid-column: 1 / -1;">
        <div class="card-header">
          <h2 class="card-title">Peak Hours (Bangkok Time)</h2>
        </div>
        <div class="card-body">
          <% const maxHourCount = Math.max(...byHour.map(h => h.count)) || 1; %>
          <div style="display:flex; align-items:flex-end; gap:4px; height:80px;">
            <% byHour.forEach(function(h) { %>
              <div style="flex:1; display:flex; flex-direction:column; align-items:center; gap:2px;">
                <div style="width:100%; background:<%= h.count === maxHourCount && h.count > 0 ? '#f59e0b' : '#6366f1' %>; height:<%= Math.round(h.count/maxHourCount*70) %>px; border-radius:3px 3px 0 0; min-height:<%= h.count > 0 ? 3 : 0 %>px;" title="<%= h.hour %>:00 — <%= h.count %> leads"></div>
                <span style="font-size:9px; color:#888;"><%= h.hour %></span>
              </div>
            <% }); %>
          </div>
          <% const peakHour = byHour.reduce((a,b) => b.count > a.count ? b : a, byHour[0]); %>
          <% if (peakHour && peakHour.count > 0) { %>
            <p style="margin-top:8px; font-size:13px; color:#555;">ช่วงเวลาที่คนทักมาบ่อยที่สุด: <strong><%= peakHour.hour %>:00–<%= peakHour.hour %>:59 น.</strong> (<%= peakHour.count %> leads)</p>
          <% } %>
        </div>
      </div>

    </section>

    <!-- Date Range Filter -->
    <section class="card" style="margin-bottom:16px;">
      <div class="card-header">
        <h2 class="card-title">📅 Lead Summary by Date Range</h2>
      </div>
      <% const fmtDate = d => d.split('-').reverse().join('/'); %>
      <div class="card-body" style="display:flex; gap:24px; flex-wrap:wrap; align-items:flex-start;">
        <div style="flex:1; min-width:300px;">
          <form method="GET" action="/" style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
            <label style="font-size:13px; color:#555;">จาก</label>
            <input type="date" name="from" value="<%= rangeFrom %>" style="padding:6px 10px; border:1px solid #ddd; border-radius:6px; font-size:13px;" required />
            <label style="font-size:13px; color:#555;">ถึง</label>
            <input type="date" name="to" value="<%= rangeTo %>" style="padding:6px 10px; border:1px solid #ddd; border-radius:6px; font-size:13px;" required />
            <button type="submit" style="padding:6px 18px; background:#6366f1; color:#fff; border:none; border-radius:6px; font-size:13px; cursor:pointer;">ดูผล</button>
            <% if (rangeFrom && rangeTo) { %>
              <a href="/" style="padding:6px 12px; color:#888; font-size:13px; text-decoration:none;">ล้าง</a>
            <% } %>
          </form>
          <% if (rangeFrom && rangeTo) { %>
            <div style="margin-top:14px;">
              <p style="font-size:15px; color:#333;">ช่วง <strong><%= fmtDate(rangeFrom) %></strong> ถึง <strong><%= fmtDate(rangeTo) %></strong>: มี lead เข้ามาทั้งหมด <strong style="color:#6366f1; font-size:20px;"><%= rangeTotal %></strong> รายการ</p>
              <% if (rangeByChannel.length > 0) { %>
                <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:10px;">
                  <% rangeByChannel.sort((a,b) => parseInt(b.count) - parseInt(a.count)).forEach(function(r) { %>
                    <span style="background:#f3f4f6; border-radius:20px; padding:4px 14px; font-size:13px; color:#444;"><%= r.channel %>: <strong><%= r.count %></strong></span>
                  <% }); %>
                </div>
              <% } %>
            </div>
          <% } %>
        </div>
        <!-- Export Button -->
        <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; min-width:140px;">
          <% if (rangeFrom && rangeTo) { %>
            <a href="/export?from=<%= rangeFrom %>&to=<%= rangeTo %>" style="display:flex; flex-direction:column; align-items:center; gap:6px; padding:14px 20px; background:#16a34a; color:#fff; border-radius:10px; text-decoration:none; font-size:13px; font-weight:600;">
              <span style="font-size:24px;">📥</span>Export Excel<br/><span style="font-weight:400; font-size:11px;"><%= fmtDate(rangeFrom) %> – <%= fmtDate(rangeTo) %></span>
            </a>
          <% } else { %>
            <a href="/export" style="display:flex; flex-direction:column; align-items:center; gap:6px; padding:14px 20px; background:#16a34a; color:#fff; border-radius:10px; text-decoration:none; font-size:13px; font-weight:600;">
              <span style="font-size:24px;">📥</span>Export Excel<br/><span style="font-weight:400; font-size:11px;">ทุก lead</span>
            </a>
          <% } %>
        </div>
      </div>
    </section>

    <!-- LEAD TABLE -->
    <section class="card table-card">
      <div class="card-header table-header">
        <h2 class="card-title">All Leads</h2>
        <div class="table-filters">
          <button id="addLeadBtn" class="btn-add-lead">+ Add Lead</button>
          <select id="filterChannel" class="filter-select">
            <option value="">All Channels</option>
            <option value="Facebook - Oakwood">Facebook - Oakwood</option>
            <option value="Facebook - Charm">Facebook - Charm</option>
            <option value="Facebook - Zodiac">Facebook - Zodiac</option>
            <option value="Line - Oakwood">Line - Oakwood</option>
            <option value="Line - Charm">Line - Charm</option>
            <option value="Telephone">Telephone</option>
            <option value="Walk-in">Walk-in</option>
          </select>
          <select id="filterStatus" class="filter-select">
            <option value="">All Status</option>
            <option value="new">New</option>
            <option value="follow-up">Follow-up</option>
            <option value="booked">Booked</option>
            <option value="lost">Lost</option>
          </select>
          <input type="text" id="filterSearch" class="filter-input" placeholder="Search name or message…" />
        </div>
        <div id="filterCount" style="font-size:13px; color:#6366f1; font-weight:600; padding:4px 0 0 2px; display:none;"></div>
      </div>
      <div class="table-wrap">
        <table class="leads-table" id="leadsTable">
          <thead>
            <tr>
              <th>Received</th>
              <th>#</th>
              <th>Name</th>
              <th>Channel</th>
              <th>Package</th>
              <th>Message</th>
              <th>Check-in</th>
              <th>Nights</th>
              <th>Status</th>
              <th>Agent</th>

              <th></th>
            </tr>
          </thead>
          <tbody>
            <% leads.forEach(function(lead) { %>
            <tr data-channel="<%= lead.channel %>" data-status="<%= lead.status %>" data-id="<%= lead.id %>">
              <td class="td-date"><%= new Date(new Date(lead.created_at).toLocaleString('en-US', {timeZone:'Asia/Bangkok'})).toLocaleDateString('en-GB').replace(/\//g,'/') + ' ' + new Date(new Date(lead.created_at).toLocaleString('en-US', {timeZone:'Asia/Bangkok'})).toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit',hour12:false}) %></td>
              <td class="td-id"><%= lead.id %></td>
              <td class="td-name">
                <button class="btn-icon btn-edit" title="Edit" data-id="<%= lead.id %>"
                  data-name="<%= lead.name %>"
                  data-phone="<%= lead.phone || '' %>"
                  data-channel="<%= lead.channel %>"
                  data-package="<%= lead.package_interest || '' %>"
                  data-checkin="<%= lead.checkin_date || '' %>"
                  data-nights="<%= lead.nights || '' %>"
                  data-message="<%= lead.message || '' %>"
                  data-agent="<%= lead.agent || '' %>"
                  >✏️</button>
                <%= lead.name %>
              </td>
              <td>
                <span class="ch-badge ch-<%= lead.channel.toLowerCase() %>"><%= lead.channel %></span>
              </td>
              <td>
                <% if (lead.package_interest) { %>
                  <span class="pkg-badge"><%= lead.package_interest %></span>
                <% } else { %>
                  <span class="td-empty">—</span>
                <% } %>
              </td>
              <td class="td-message" title="<%= lead.message %>"><%= lead.message %></td>
              <td class="td-checkin">
                <input type="date" class="inline-input checkin-input" value="<%= lead.checkin_date || '' %>" data-field="checkin_date" />
              </td>
              <td>
                <input type="number" min="1" max="365" class="inline-input nights-input" value="<%= lead.nights || '' %>" placeholder="—" data-field="nights" />
              </td>
              <td>
                <select class="status-select status-<%= lead.status %>" data-id="<%= lead.id %>">
                  <option value="new"      <%= lead.status === 'new'       ? 'selected' : '' %>>New</option>
                  <option value="follow-up"<%= lead.status === 'follow-up' ? 'selected' : '' %>>Follow-up</option>
                  <option value="booked"   <%= lead.status === 'booked'    ? 'selected' : '' %>>Booked</option>
                  <option value="lost"     <%= lead.status === 'lost'      ? 'selected' : '' %>>Lost</option>
                </select>
              </td>
              <td class="td-agent"><%= lead.agent || '—' %></td>

              <td class="td-actions">
                <button class="btn-icon btn-delete" title="Delete" data-id="<%= lead.id %>" data-name="<%= lead.name %>">🗑️</button>
              </td>
            </tr>
            <% }); %>
            <% if (leads.length === 0) { %>
            <tr><td colspan="11" class="td-empty-row">No leads yet. Webhooks are ready.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Package Manager -->
    <section class="card" style="margin-top:16px;" id="packageManager">
      <div class="card-header">
        <h2 class="card-title">🏷️ จัดการ Package / Promotion</h2>
      </div>
      <div class="card-body">
        <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px;" id="pkgList">
          <% packages.forEach(p => { %>
            <span style="display:inline-flex; align-items:center; gap:6px; background:#f3f4f6; border-radius:20px; padding:5px 14px; font-size:13px;">
              <%= p.name %>
              <button onclick="deletePackage(<%= p.id %>, this)" style="background:none; border:none; cursor:pointer; color:#999; font-size:14px; padding:0; line-height:1;">✕</button>
            </span>
          <% }); %>
        </div>
        <div style="display:flex; gap:8px; align-items:center;">
          <input type="text" id="newPkgName" placeholder="ชื่อ package ใหม่..." style="padding:7px 12px; border:1px solid #ddd; border-radius:6px; font-size:13px; flex:1; max-width:280px;" />
          <button onclick="addPackage()" style="padding:7px 18px; background:#6366f1; color:#fff; border:none; border-radius:6px; font-size:13px; cursor:pointer;">+ เพิ่ม</button>
        </div>
        <p id="pkgMsg" style="font-size:12px; color:#888; margin-top:6px;"></p>
      </div>
    </section>

  </main>

  <!-- EDIT LEAD MODAL -->
  <div id="editModalOverlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="editModalTitle">
      <div class="modal-header">
        <h2 class="modal-title" id="editModalTitle">Edit Lead</h2>
        <button class="modal-close" id="editModalClose">&times;</button>
      </div>
      <form id="editLeadForm" class="modal-body" novalidate>
        <input type="hidden" id="el-id" name="id" />

        <div class="form-row">
          <div class="form-group form-group--grow">
            <label class="form-label" for="el-name">Name <span class="req">*</span></label>
            <input type="text" id="el-name" name="name" class="form-input" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="el-phone">Phone</label>
            <input type="tel" id="el-phone" name="phone" class="form-input" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="el-channel">Channel <span class="req">*</span></label>
            <select id="el-channel" name="channel" class="form-input" required>
              <option value="">Select…</option>
              <option value="Facebook - Oakwood">Facebook - Oakwood</option>
              <option value="Facebook - Charm">Facebook - Charm</option>
              <option value="Facebook - Zodiac">Facebook - Zodiac</option>
              <option value="Line - Oakwood">Line - Oakwood</option>
              <option value="Line - Charm">Line - Charm</option>
              <option value="Telephone">Telephone</option>
              <option value="Walk-in">Walk-in</option>
              <option value="In-house Guest">In-house Guest</option>
            </select>
          </div>
          <div class="form-group form-group--grow">
            <label class="form-label" for="el-agent">คนรับจอง <span class="req">*</span></label>
            <select id="el-agent" name="agent" class="form-input" required>
              <option value="">Select...</option>
              <option value="Reservation">Reservation</option>
              <option value="Marketing">Marketing</option>
              <option value="Charm Cuisine">Charm Cuisine</option>
              <option value="Front Officer">Front Officer</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group form-group--grow">
            <label class="form-label" for="el-package">Package Interest</label>
            <select id="el-package" name="package_interest" class="form-input">
              <option value="">None / Unknown</option>
              <% packages.forEach(p => { %><option value="<%= p.name %>"><%= p.name %></option><% }); %>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="el-checkin">Check-in Date</label>
            <input type="date" id="el-checkin" name="checkin_date" class="form-input" />
          </div>
          <div class="form-group form-group--sm">
            <label class="form-label" for="el-nights">Nights</label>
            <input type="number" id="el-nights" name="nights" class="form-input" min="1" max="365" placeholder="—" />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="el-message">Message / Note</label>
          <textarea id="el-message" name="message" class="form-input form-textarea" rows="3"></textarea>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn-secondary" id="editModalCancel">Cancel</button>
          <button type="submit" class="btn-primary" id="editModalSubmit">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ADD LEAD MODAL -->
  <div id="modalOverlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
      <div class="modal-header">
        <h2 class="modal-title" id="modalTitle">Add Lead</h2>
        <button class="modal-close" id="modalClose" aria-label="Close">&times;</button>
      </div>
      <form id="addLeadForm" class="modal-body" novalidate>

        <div class="form-row">
          <div class="form-group form-group--grow">
            <label class="form-label" for="fl-name">Name <span class="req">*</span></label>
            <input type="text" id="fl-name" name="name" class="form-input" placeholder="Guest name" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="fl-phone">Phone</label>
            <input type="tel" id="fl-phone" name="phone" class="form-input" placeholder="0812345678" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="fl-channel">Channel <span class="req">*</span></label>
            <select id="fl-channel" name="channel" class="form-input" required>
              <option value="">Select…</option>
              <option value="Facebook - Oakwood">Facebook - Oakwood</option>
              <option value="Facebook - Charm">Facebook - Charm</option>
              <option value="Facebook - Zodiac">Facebook - Zodiac</option>
              <option value="Line - Oakwood">Line - Oakwood</option>
              <option value="Line - Charm">Line - Charm</option>
              <option value="Telephone">Telephone</option>
              <option value="Walk-in">Walk-in</option>
              <option value="In-house Guest">In-house Guest</option>
            </select>
          </div>
          <div class="form-group form-group--grow">
            <label class="form-label" for="fl-agent">คนรับจอง <span class="req">*</span></label>
            <select id="fl-agent" name="agent" class="form-input" required>
              <option value="">Select...</option>
              <option value="Reservation">Reservation</option>
              <option value="Marketing">Marketing</option>
              <option value="Charm Cuisine">Charm Cuisine</option>
              <option value="Front Officer">Front Officer</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group form-group--grow">
            <label class="form-label" for="fl-package">Package Interest</label>
            <select id="fl-package" name="package_interest" class="form-input">
              <option value="">None / Unknown</option>
              <% packages.forEach(p => { %><option value="<%= p.name %>"><%= p.name %></option><% }); %>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="fl-checkin">Check-in Date</label>
            <input type="date" id="fl-checkin" name="checkin_date" class="form-input" />
          </div>
          <div class="form-group form-group--sm">
            <label class="form-label" for="fl-nights">Nights</label>
            <input type="number" id="fl-nights" name="nights" class="form-input" min="1" max="365" placeholder="—" />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="fl-message">Message / Note</label>
          <textarea id="fl-message" name="message" class="form-input form-textarea" rows="3" placeholder="What did the guest ask about?"></textarea>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn-secondary" id="modalCancel">Cancel</button>
          <button type="submit" class="btn-primary" id="modalSubmit">Save Lead</button>
        </div>

      </form>
    </div>
  </div>

  <!-- TOAST -->
  <div id="toast" class="toast"></div>

  <script src="/js/dashboard.js"></script>
  <script>
    async function addPackage() {
      const input = document.getElementById('newPkgName');
      const msg = document.getElementById('pkgMsg');
      const name = input.value.trim();
      if (!name) return;
      const res = await fetch('/api/packages', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({name}) });
      const data = await res.json();
      if (!data.ok) { msg.textContent = data.error || 'เกิดข้อผิดพลาด'; return; }
      msg.textContent = `เพิ่ม "${name}" แล้วค่ะ`;
      input.value = '';
      setTimeout(() => location.reload(), 800);
    }
    document.getElementById('newPkgName').addEventListener('keydown', e => { if (e.key === 'Enter') addPackage(); });

    async function deletePackage(id, btn) {
      if (!confirm('ลบ package นี้?')) return;
      const res = await fetch(`/api/packages/${id}`, { method:'DELETE' });
      if ((await res.json()).ok) { btn.closest('span').remove(); }
    }
  </script>
</body>
</html>
